FROM golang:1.21-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o geofencing-service ./cmd/server/main.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates postgis
WORKDIR /root/
COPY --from=builder /app/geofencing-service .
EXPOSE 50059
CMD ["./geofencing-service"]